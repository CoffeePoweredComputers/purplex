# =====================================================================================
# PURPLEX ENVIRONMENT CONFIGURATION - BASIC EXAMPLE
# =====================================================================================
#
# This is a minimal example configuration for getting started quickly.
# For detailed documentation, see:
#   - .env.development.template - Development environment template
#   - .env.production.template - Production environment template
#
# Quick Start:
#   1. Copy this file to .env
#   2. Set your OpenAI API key
#   3. Run ./start.sh
#
# =====================================================================================

# Environment
PURPLEX_ENV=development

# Django
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_URL=postgresql://purplex_user:devpass@localhost:5432/purplex_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenAI (REQUIRED - Get your key from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here
GPT_MODEL=gpt-4o-mini

# Firebase (Optional - Uses mock in development if not set)
USE_MOCK_FIREBASE=true