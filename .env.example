# =====================================================
# PURPLEX ENVIRONMENT CONFIGURATION
# =====================================================
# Copy this file to .env and update with your values
# NEVER commit .env to version control

# Environment Type
PURPLEX_ENV=production

# =====================================================
# DATABASE CREDENTIALS
# =====================================================
# For development: Use simple passwords
# For production: Generate strong passwords with:
#   openssl rand -base64 32
# OR retrieve from AWS Secrets Manager (see deployment guide)

POSTGRES_DB=purplex_prod
POSTGRES_USER=purplex_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# =====================================================
# REDIS CREDENTIALS
# =====================================================
# Optional: Leave empty for development, set for production
REDIS_PASSWORD=

# =====================================================
# DJANGO CONFIGURATION
# =====================================================
# Generate Django secret key with:
#   python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY_HERE
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# =====================================================
# DATABASE URL (Auto-constructed from above)
# =====================================================
# This is constructed from POSTGRES_* variables above
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# =====================================================
# REDIS URL (Auto-constructed from above)
# =====================================================
REDIS_URL=redis://:${REDIS_PASSWORD:-}@redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD:-}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD:-}@redis:6379/2

# =====================================================
# AI CONFIGURATION
# =====================================================
# Uses the OpenAI SDK — works with any OpenAI-compatible API.
USE_MOCK_OPENAI=false
OPENAI_API_KEY=sk-YOUR_API_KEY_HERE
# OPENAI_BASE_URL=                    # Optional: for non-OpenAI providers
GPT_MODEL=gpt-4o-mini

# =====================================================
# FIREBASE CONFIGURATION
# =====================================================
# Path to Firebase service account credentials JSON file
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# =====================================================
# SSL/SECURITY SETTINGS
# =====================================================
# Set to True only when using HTTPS with valid certificates
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_TRUSTED_ORIGINS=http://your-domain.com

# =====================================================
# PERFORMANCE SETTINGS
# =====================================================
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
CELERY_WORKERS=4

# =====================================================
# CODE EXECUTION SETTINGS
# =====================================================
CODE_EXEC_MAX_TIME=10
CODE_EXEC_MAX_MEMORY=512m

# =====================================================
# FEATURE FLAGS
# =====================================================
ENABLE_EIPL=True
ENABLE_HINTS=True
ENABLE_COURSES=True

# =====================================================
# AWS SECRETS MANAGER (Production Only)
# =====================================================
# If using AWS Secrets Manager, the deployment script will
# automatically populate these variables from the secret.
# Leave these commented for manual .env configuration.
#
# AWS_SECRET_NAME=purplex/production/credentials
# AWS_REGION=us-east-2
