{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3BackupAccess",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:ListBucket",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::purplex-db-backups",
                "arn:aws:s3:::purplex-db-backups/*"
            ]
        },
        {
            "Sid": "S3ListAllBuckets",
            "Effect": "Allow",
            "Action": "s3:ListAllMyBuckets",
            "Resource": "*"
        }
    ]
}