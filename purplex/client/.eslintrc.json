{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:vue/vue3-recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "parser": "vue-eslint-parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "parser": "@typescript-eslint/parser",
    "sourceType": "module"
  },
  "plugins": ["vue", "@typescript-eslint", "@intlify/vue-i18n"],
  "settings": {
    "vue-i18n": {
      "localeDir": "./src/i18n/locales/{en,es}/*.json",
      "messageSyntaxVersion": "^9.0.0"
    }
  },
  "rules": {
    // Disallow all console statements - use logger utility instead
    "no-console": "error",

    // Vue specific rules
    "vue/multi-word-component-names": "off",
    "vue/no-v-html": "warn",
    "vue/require-default-prop": "error",
    "vue/require-explicit-emits": "error",
    "vue/no-unused-vars": "error",
    "vue/no-unused-components": "error",
    "vue/prefer-import-from-vue": "error",
    "vue/no-ref-as-operand": "error",

    // Component size limit
    "max-lines": ["warn", {
      "max": 500,
      "skipBlankLines": true,
      "skipComments": true
    }],

    // TypeScript specific rules
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/explicit-function-return-type": "off",
    "@typescript-eslint/no-unused-vars": ["error", {
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^_"
    }],

    // General code quality
    "no-unused-vars": "off", // Use TypeScript's no-unused-vars instead
    "prefer-const": "error",
    "no-var": "error",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "no-throw-literal": "error",

    // Async/await best practices
    "no-return-await": "error",
    "require-await": "error",
    "no-async-promise-executor": "error",

    // Import rules
    "no-duplicate-imports": "error",
    "sort-imports": ["error", {
      "ignoreCase": true,
      "ignoreDeclarationSort": true
    }],

    // i18n rules - enforce localization of all user-facing strings
    "@intlify/vue-i18n/no-raw-text": ["error", {
      "ignoreNodes": ["md-icon", "v-icon"],
      "ignorePattern": "^[^a-zA-Z]+$",
      "ignoreText": ["&nbsp;", "&amp;", "—", "–", "·", "•", "|", "/", "×"]
    }],
    "@intlify/vue-i18n/no-missing-keys": "error",
    "@intlify/vue-i18n/no-unused-keys": ["warn", {
      "extensions": [".ts", ".vue"]
    }],
    "@intlify/vue-i18n/no-duplicate-keys-in-locale": "error",
    "@intlify/vue-i18n/no-missing-keys-in-other-locales": "error",
    "@intlify/vue-i18n/key-format-style": ["error", "camelCase", {
      "allowArray": false
    }]
  },
  "overrides": [
    {
      "files": ["*.vue"],
      "rules": {
        "max-lines": ["warn", {
          "max": 600,
          "skipBlankLines": true,
          "skipComments": true
        }]
      }
    }
  ]
}
