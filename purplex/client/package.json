{
  "name": "purplex-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Vue 3 + TypeScript frontend for the Purplex educational coding challenge platform",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/CoffeePoweredComputers/purplex.git",
    "directory": "purplex/client"
  },
  "bugs": {
    "url": "https://github.com/CoffeePoweredComputers/purplex/issues"
  },
  "homepage": "https://github.com/CoffeePoweredComputers/purplex#readme",
  "scripts": {
    "django": "python ../../manage.py runserver",
    "dev": "concurrently \"yarn vite --mode development\" \"yarn django\"",
    "prod": "concurrently \"yarn vite --mode production\" \"yarn django\"",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "build:prod": "NODE_ENV=production vite build",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dead-code": "knip",
    "dead-code:fix": "knip --fix",
    "i18n:check": "node scripts/check-i18n.mjs",
    "i18n:badges": "node scripts/generate-i18n-badges.mjs"
  },
  "dependencies": {
    "ace-builds": "^1.32.5",
    "axios": "^1.7.3",
    "concurrently": "^8.2.2",
    "firebase": "^10.12.5",
    "marked": "^15.0.12",
    "vue": "^3.3.11",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.4.2",
    "vue3-ace-editor": "^2.2.4",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@intlify/eslint-plugin-vue-i18n": "^4.3.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.24.0",
    "happy-dom": "^18.0.1",
    "jsonc-eslint-parser": "^3.1.0",
    "knip": "^5.70.2",
    "rollup-plugin-visualizer": "^6.0.3",
    "terser": "^5.26.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^9.4.2",
    "vue-tsc": "^1.8.25",
    "yaml-eslint-parser": "^2.0.0"
  }
}
