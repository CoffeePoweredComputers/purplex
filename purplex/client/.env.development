# Frontend Development Environment Variables
# These are loaded by Vite in development mode

# API Configuration
VITE_API_URL=http://localhost:8000

# Environment
VITE_PURPLEX_ENV=development

# Use mock Firebase in development
VITE_FIREBASE_MOCK=true

# Feature flags
VITE_ENABLE_EIPL=true
VITE_ENABLE_HINTS=true
VITE_ENABLE_COURSES=true

# Debug options
VITE_DEBUG=false
VITE_SHOW_DEBUG_TOOLBAR=false