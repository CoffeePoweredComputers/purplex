# ============================================================================
# Purplex Production Environment Configuration Template
# ============================================================================
# SECURITY WARNING: This is a TEMPLATE file. Copy to .env.production and fill
# in actual values. NEVER commit .env.production to version control.
# ============================================================================
# Usage:
#   1. Copy this file: cp .env.production.template .env.production
#   2. Fill in all REQUIRED values marked with <REQUIRED>
#   3. Review and configure OPTIONAL values as needed
#   4. Ensure .env.production is in .gitignore
#   5. Validate: python manage.py check --deploy
# ============================================================================

# ============================================================================
# CORE ENVIRONMENT
# ============================================================================
PURPLEX_ENV=production

# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================

# Django secret key (REQUIRED)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# SECURITY: Must be unique, random, and kept secret
DJANGO_SECRET_KEY=<REQUIRED-GENERATE-SECURE-SECRET-KEY>

# Debug mode (MUST be false in production)
DJANGO_DEBUG=false

# Allowed hosts (REQUIRED - comma-separated list of domains/IPs)
# For purplex.org deployment:
# DJANGO_ALLOWED_HOSTS=purplex.org,www.purplex.org,localhost,127.0.0.1
# Example with IP: DJANGO_ALLOWED_HOSTS=54.123.45.67,purplex.org,www.purplex.org,localhost,127.0.0.1
# SECURITY: NEVER use wildcard '*' in production
DJANGO_ALLOWED_HOSTS=purplex.org,www.purplex.org,localhost,127.0.0.1

# Server URL for internal links (REQUIRED)
# For purplex.org deployment:
SERVER_URL=https://purplex.org

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection (REQUIRED)
# Format: postgresql://username:password@host:port/database
# AWS RDS Example: postgresql://purplex_user:STRONG_PASSWORD@purplex-db.abc123.us-east-1.rds.amazonaws.com:5432/purplex_prod
# Docker Example: postgresql://purplex_user:STRONG_PASSWORD@postgres:5432/purplex_prod
DATABASE_URL=<REQUIRED-POSTGRESQL-CONNECTION-STRING>

# Connection pooling (production optimized)
DB_CONN_MAX_AGE=600
DB_POOL_SIZE=20

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

# Redis connection (REQUIRED)
# Format: redis://host:port/database
# AWS ElastiCache Example: redis://purplex-redis.abc123.cache.amazonaws.com:6379/0
# Docker Example: redis://redis:6379/0
REDIS_URL=<REQUIRED-REDIS-CONNECTION-STRING>

# Redis host and port (for services that don't use URL format)
REDIS_HOST=<REQUIRED-REDIS-HOSTNAME>
REDIS_PORT=6379

# Redis memory limit
REDIS_MAX_MEMORY=2gb

# ============================================================================
# CELERY CONFIGURATION
# ============================================================================

# Celery broker (use Redis database 0)
CELERY_BROKER_URL=<REQUIRED-SAME-AS-REDIS-URL>

# Celery result backend (use Redis database 1)
# Change the /0 to /1 in your Redis URL
CELERY_RESULT_BACKEND=<REQUIRED-REDIS-URL-WITH-DB-1>

# Task time limits (production values)
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500

# Worker lifecycle (prevent memory leaks)
CELERY_MAX_TASKS_PER_CHILD=1000

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# --- Firebase Authentication (REQUIRED) ---
USE_MOCK_FIREBASE=false

# Path to Firebase service account credentials JSON file
# The file should be uploaded to your server (NOT in version control)
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# --- AI Configuration (REQUIRED) ---
USE_MOCK_OPENAI=false

# API key for your OpenAI-compatible provider
# SECURITY: Keep this secret, use environment variable or secrets manager
OPENAI_API_KEY=<REQUIRED-YOUR-API-KEY>

# Optional: base URL for non-OpenAI providers (leave unset for api.openai.com)
# OPENAI_BASE_URL=

# Model name (must exist at your provider)
GPT_MODEL=gpt-4o-mini

# ============================================================================
# SECURITY SETTINGS (Production)
# ============================================================================

# SSL/HTTPS Settings
# Set to true ONLY if you have HTTPS configured (recommended)
# If using HTTP (not recommended), leave as false
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

# Enforce SSL security checks in production
# Set to true ONLY if SECURE_SSL_REDIRECT=true
ENFORCE_SSL_IN_PRODUCTION=false

# Frame options (DENY is most secure)
X_FRAME_OPTIONS=DENY

# CSRF trusted origins (REQUIRED if using frontend on different domain)
# Must match your actual domains, including https:// if using SSL
# For purplex.org deployment:
CSRF_TRUSTED_ORIGINS=https://purplex.org,https://www.purplex.org

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================

# CORS allowed origins (REQUIRED - comma-separated list)
# Must match your actual frontend URLs with protocol (http:// or https://)
# For purplex.org deployment:
CORS_ALLOWED_ORIGINS=https://purplex.org,https://www.purplex.org

# ============================================================================
# RESOURCE LIMITS (Production)
# ============================================================================

# File upload limits (more restrictive in production)
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880

# Content length limits (more restrictive in production)
MAX_PROMPT_LENGTH=2000
MAX_CODE_LENGTH=50000

# ============================================================================
# CODE EXECUTION SECURITY (Production)
# ============================================================================

# Docker-based code execution limits (more restrictive)
CODE_EXEC_MAX_TIME=5
CODE_EXEC_MAX_MEMORY=256m
CODE_EXEC_MAX_CPU=50

# Docker pool health monitoring (production settings)
DOCKER_POOL_HEALTH_CHECK_INTERVAL=60   # Seconds between health checks (60 = aggressive monitoring)
DOCKER_POOL_CONTAINER_MAX_AGE=3600     # Max container age in seconds (3600 = 1 hour, prevent memory leaks)
DOCKER_POOL_MAX_RESTART_ATTEMPTS=3     # Max restart attempts before removal

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log levels (less verbose in production)
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING

# Log file paths (absolute paths in container)
DJANGO_LOG_FILE=/app/logs/django.log
ERROR_LOG_FILE=/app/logs/errors.log
ACCESS_LOG_FILE=/app/logs/access.log

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Core features (all enabled by default)
ENABLE_EIPL=true
ENABLE_HINTS=true
ENABLE_COURSES=true

# Debug tools (MUST be false in production)
ENABLE_DEBUG_TOOLBAR=false
SHOW_DEBUG_TOOLBAR=false
ENABLE_QUERY_LOGGING=false
ENABLE_REQUEST_LOGGING=false

# ============================================================================
# RATE LIMITING (Production)
# ============================================================================

# Rate limiting (STRONGLY RECOMMENDED for production)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=5

# ============================================================================
# GUNICORN SETTINGS (Production)
# ============================================================================

# Number of worker processes (formula: 2 * CPU_CORES + 1)
# For AWS t3.medium (2 vCPUs): GUNICORN_WORKERS=5
# For AWS t3.large (2 vCPUs): GUNICORN_WORKERS=5
# For AWS c5.xlarge (4 vCPUs): GUNICORN_WORKERS=9
GUNICORN_WORKERS=5

# Timeout for worker requests
GUNICORN_TIMEOUT=30
GUNICORN_GRACEFUL_TIMEOUT=30

# Worker class (sync for CPU-bound, gevent for I/O-bound)
GUNICORN_WORKER_CLASS=sync

# Threads per worker (for sync workers)
GUNICORN_THREADS=4

# Worker connections (for gevent workers)
GUNICORN_WORKER_CONNECTIONS=1000

# Request limits (restart workers to prevent memory leaks)
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=50

# Logging
GUNICORN_LOG_LEVEL=info
GUNICORN_ACCESS_LOG=/app/logs/access.log
GUNICORN_ERROR_LOG=/app/logs/error.log

# ============================================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================================

# Email backend for error notifications
EMAIL_BACKEND=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true

# Email credentials (OPTIONAL - only if sending emails)
EMAIL_HOST_USER=<OPTIONAL-EMAIL-USERNAME>
EMAIL_HOST_PASSWORD=<OPTIONAL-EMAIL-PASSWORD>

# Email addresses
DEFAULT_FROM_EMAIL=noreply@purplex.example.com
SERVER_EMAIL=server@purplex.example.com
ADMIN_EMAIL=<OPTIONAL-ADMIN-EMAIL>

# ============================================================================
# MONITORING & ERROR TRACKING (Optional but Recommended)
# ============================================================================

# Sentry Error Tracking (OPTIONAL but highly recommended for production)
# Sentry provides real-time error tracking and performance monitoring
# Free tier: 5,000 events/month, 10,000 performance transactions/month
# Sign up at https://sentry.io and create a Django project to get your DSN
#
# Setup steps:
# 1. Create account at https://sentry.io
# 2. Create new project → Select "Django"
# 3. Copy the DSN (looks like: https://key@org.ingest.sentry.io/project-id)
# 4. Uncomment and set SENTRY_DSN below
# 5. Restart application to enable monitoring
#
# SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id
SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=  # Auto-set via CI/CD (git commit SHA recommended)

# Sentry Sampling Configuration
# Adjust these based on your traffic and quota usage
# Higher sampling = more visibility, but uses quota faster
SENTRY_TRACES_SAMPLE_RATE=0.1  # 10% of transactions (adjust based on traffic)
SENTRY_PROFILES_SAMPLE_RATE=0.0  # Disabled by default (consumes quota quickly)

# Note: Custom sampling logic in production.py prioritizes critical endpoints:
# - EiPL submissions: 100% sampled (always monitored)
# - API endpoints: 50% sampled
# - Health checks: 5% sampled
# - Admin pages: 10% sampled

# ============================================================================
# DOCKER COMPOSE VARIABLES (If using Docker)
# ============================================================================

# PostgreSQL container settings
POSTGRES_DB=purplex_prod
POSTGRES_USER=purplex_user
POSTGRES_PASSWORD=<REQUIRED-STRONG-DATABASE-PASSWORD>

# Service ports
WEB_PORT=8000

# Worker concurrency
CELERY_WORKERS=4

# ============================================================================
# AWS-SPECIFIC SETTINGS (If deploying to AWS)
# ============================================================================

# AWS region (if needed)
# AWS_REGION=us-east-1

# AWS S3 for static files (OPTIONAL)
# AWS_STORAGE_BUCKET_NAME=<YOUR-S3-BUCKET>
# AWS_S3_REGION_NAME=us-east-1
# AWS_ACCESS_KEY_ID=<YOUR-AWS-ACCESS-KEY>
# AWS_SECRET_ACCESS_KEY=<YOUR-AWS-SECRET-KEY>

# ============================================================================
# VALIDATION CHECKLIST
# ============================================================================
# Before deploying, verify:
# [ ] All <REQUIRED> fields are filled with actual values
# [ ] DJANGO_SECRET_KEY is unique and random (not the default)
# [ ] DJANGO_ALLOWED_HOSTS contains your actual domain/IP
# [ ] DATABASE_URL points to production database
# [ ] REDIS_URL points to production Redis
# [ ] Firebase credentials file is uploaded to server
# [ ] OPENAI_API_KEY is valid
# [ ] SSL settings match your HTTPS configuration
# [ ] CSRF_TRUSTED_ORIGINS and CORS_ALLOWED_ORIGINS are correct
# [ ] All passwords are strong and unique
# [ ] .env.production is NOT committed to version control
# [ ] Run: python manage.py check --deploy
