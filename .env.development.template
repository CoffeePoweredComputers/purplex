# =====================================================================================
# PURPLEX DEVELOPMENT ENVIRONMENT CONFIGURATION TEMPLATE
# =====================================================================================
#
# This template contains all configuration options for development environments.
# Copy this file to .env.development and adjust values as needed.
#
# For production configuration, see .env.production.template
#
# =====================================================================================

# =====================================================================================
# ENVIRONMENT CORE
# =====================================================================================

# Environment name
PURPLEX_ENV=development

# =====================================================================================
# DJANGO SETTINGS
# =====================================================================================

# Secret key (use a simple one for dev, but unique per developer)
DJANGO_SECRET_KEY=dev-secret-key-change-this-for-each-developer

# Debug mode - typically True for development
DJANGO_DEBUG=True

# Allowed hosts - add your local network IP if testing from other devices
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Django settings module
DJANGO_SETTINGS_MODULE=purplex.settings

# =====================================================================================
# DATABASE
# =====================================================================================

# PostgreSQL connection
DATABASE_URL=postgresql://purplex_user:devpass@localhost:5432/purplex_dev

# Alternative individual settings
POSTGRES_DB=purplex_dev
POSTGRES_USER=purplex_user
POSTGRES_PASSWORD=devpass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =====================================================================================
# REDIS & CACHE
# =====================================================================================

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Redis URLs for different purposes
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CACHE_URL=redis://localhost:6379/2

# =====================================================================================
# CELERY
# =====================================================================================

# Task limits (shorter for dev to catch issues faster)
CELERY_TASK_TIME_LIMIT=300        # 5 minutes
CELERY_TASK_SOFT_TIME_LIMIT=240   # 4 minutes

# Worker settings
CELERY_CONCURRENCY_DEFAULT=4
CELERY_MAX_TASKS_PER_CHILD=100

# =====================================================================================
# EXTERNAL SERVICES
# =====================================================================================

# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here
GPT_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=30

# Firebase - Mock by default for development
USE_MOCK_FIREBASE=true
# If using real Firebase in dev:
# FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
# FIREBASE_PROJECT_ID=your-project-id

# Mock services
USE_MOCK_OPENAI=false  # Set to true to mock OpenAI calls

# =====================================================================================
# CORS & NETWORK
# =====================================================================================

# CORS - Allow frontend dev server
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173

# Server URL
SERVER_URL=http://localhost:8000

# =====================================================================================
# FILE PATHS
# =====================================================================================

# Static files
STATIC_ROOT=./staticfiles
STATIC_URL=/static/

# Media files
MEDIA_ROOT=./media
MEDIA_URL=/media/

# Logs
DJANGO_LOG_FILE=./logs/django.log
ERROR_LOG_FILE=./logs/errors.log

# =====================================================================================
# RESOURCE LIMITS (relaxed for development)
# =====================================================================================

# File upload limits
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760    # 10MB
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760    # 10MB
MAX_REQUEST_SIZE=20971520                # 20MB

# Code execution limits (Docker sandbox)
CODE_EXEC_MAX_TIME=10          # seconds (longer for debugging)
CODE_EXEC_MAX_MEMORY=512m      # memory limit
CODE_EXEC_MAX_CPU=100          # CPU percentage
CODE_EXEC_MAX_PROCESSES=100    # max processes

# =====================================================================================
# LOGGING
# =====================================================================================

# Log levels - more verbose for development
LOG_LEVEL=DEBUG
DJANGO_LOG_LEVEL=DEBUG
CELERY_LOG_LEVEL=DEBUG
GUNICORN_LOG_LEVEL=DEBUG

# Log format
LOG_FORMAT=standard  # 'json' or 'standard'

# =====================================================================================
# MONITORING (optional for development)
# =====================================================================================

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Flower (Celery monitoring)
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:admin

# =====================================================================================
# FEATURE FLAGS
# =====================================================================================

# Core features
ENABLE_EIPL=true
ENABLE_HINTS=true
ENABLE_COURSES=true

# Development features
ENABLE_DEBUG_TOOLBAR=true     # Django Debug Toolbar
ENABLE_API_DOCS=true          # Swagger/OpenAPI
ENABLE_ADMIN_INTERFACE=true   # Django admin
ENABLE_USER_REGISTRATION=true

# Experimental features (test in dev first)
ENABLE_AI_GRADING=false
ENABLE_PEER_REVIEW=false

# =====================================================================================
# RATE LIMITING (relaxed for development)
# =====================================================================================

# Rate limiting - disabled or relaxed for dev
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_PER_HOUR=10000

# =====================================================================================
# DEVELOPMENT-SPECIFIC
# =====================================================================================

# Auto-reload
DJANGO_AUTO_RELOAD=true

# SQL query logging
LOG_SQL_QUERIES=false  # Set to true to debug queries

# Frontend dev server
VITE_DEV_SERVER=http://localhost:5173

# Test settings
TEST_DATABASE_NAME=purplex_test
TEST_RUNNER=django.test.runner.DiscoverRunner

# =====================================================================================
# QUICK TIPS FOR DEVELOPERS
# =====================================================================================
#
# 1. Always set your OPENAI_API_KEY before running the app
# 2. Use ./start.sh to start all services automatically
# 3. Access the app at http://localhost:5173 (frontend)
# 4. Django admin at http://localhost:8000/admin
# 5. Flower (Celery monitor) at http://localhost:5555
# 6. If using WSL, you may need to adjust POSTGRES_HOST
# 7. For debugging, set LOG_LEVEL=DEBUG and DJANGO_DEBUG=True
# 8. Mock Firebase is enabled by default - no setup needed
#
# =====================================================================================